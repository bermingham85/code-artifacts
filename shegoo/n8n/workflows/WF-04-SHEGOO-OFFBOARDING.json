            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"event\": \"member_offboarded\",\n  \"member_id\": \"{{ $('Find Member by Stripe ID').item.json[0].id }}\",\n  \"details\": \"Plan: {{ $('Find Member by Stripe ID').item.json[0].plan }}\",\n  \"created_at\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "audit-log-offboard",
      "name": "Insert Audit Log",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 400]
    },
    {
      "parameters": {
        "chatId": "={{ $env.SHEGOO_OPS_CHAT_ID }}",
        "text": "=Churn \u00b7 {{ $('Find Member by Stripe ID').item.json[0].plan }}",
        "additionalFields": {}
      },
      "id": "tg-ops-churn",
      "name": "Telegram Ops Churn",
      "type": "n8n-nodes-base.telegram",
