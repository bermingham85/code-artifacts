# BERMCOIN ENVIRONMENT TEMPLATE
# Copy to .env and fill in values. NEVER commit the .env file.
# All values stored as environment variables on QNAP/workstation.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WH_CHECKOUT_SECRET=
STRIPE_WH_OFFBOARD_SECRET=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Telegram - @Brianbrainboxbot only - never create a new bot
TELEGRAM_BOT_TOKEN=
BERMCOIN_OPS_CHAT_ID=

# Brevo - transactional email only
BREVO_API_KEY=

# Meta WhatsApp Cloud API - Pro plan only
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

# Rate sources - Frankfurter is free, no key needed
FRANKFURTER_API=https://api.frankfurter.app
FALLBACK_RATE_API_1=https://open.er-api.com/v6/latest
FALLBACK_RATE_API_2=https://v6.exchangerate-api.com/v6
EXCHANGERATE_API_KEY=

# n8n
N8N_API_KEY=

# App
BERMCOIN_URL=https://bermcoin.com
BERMCOIN_SUPPORT_EMAIL=hello@bermcoin.com
