            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"affiliate_ref\": \"{{ $('Extract Checkout Data').item.json.affiliate_ref }}\",\n  \"member_email\": \"{{ $('Extract Checkout Data').item.json.email }}\",\n  \"plan\": \"{{ $('Extract Checkout Data').item.json.plan }}\",\n  \"converted_at\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "insert-affiliate",
      "name": "Insert Affiliate Conversion",
