{
  "name": "CONV-PROC Orchestrator",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 6 }]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "https://ylcepmvbjjnwmzvevxid.supabase.co/functions/v1/conv-proc-extract",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{ \"batch_size\": 5 }",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        }
      },
      "name": "Run Extraction",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "url": "https://ylcepmvbjjnwmzvevxid.supabase.co/functions/v1/conv-proc-router",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{ \"batch_size\": 5 }",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        }
      },
      "name": "Run Router",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [750, 300]
    },
    {
      "parameters": {
        "url": "https://ylcepmvbjjnwmzvevxid.supabase.co/functions/v1/conv-proc-expand",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.SUPABASE_SERVICE_KEY }}"
            }
          ]
        }
      },
      "name": "Run Expand",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300]
    }
  ],
  "connections": {
    "Schedule Trigger": { "main": [[{ "node": "Run Extraction", "type": "main", "index": 0 }]] },
    "Run Extraction": { "main": [[{ "node": "Run Router", "type": "main", "index": 0 }]] },
    "Run Router": { "main": [[{ "node": "Run Expand", "type": "main", "index": 0 }]] }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": true
  }
}
